{
  "name": "conduit-vscode",
  "displayName": "Conduit — Universal AI Bridge",
  "description": "Connect VS Code to any OpenAI-compatible AI provider: Grok, Claude, Gemini, ChatGPT and more via local proxy.",
  "version": "0.7.0",
  "publisher": "elvatis",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/elvatis/conduit-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "grok",
    "claude",
    "gemini",
    "chatgpt",
    "copilot",
    "assistant",
    "conduit"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "configuration": {
      "title": "Conduit",
      "properties": {
        "conduit.proxyUrl": {
          "type": "string",
          "default": "http://127.0.0.1:31338",
          "description": "Base URL of the OpenAI-compatible proxy (cli-bridge)"
        },
        "conduit.apiKey": {
          "type": "string",
          "default": "cli-bridge",
          "description": "API key for the proxy"
        },
        "conduit.defaultModel": {
          "type": "string",
          "default": "cli-gemini/gemini-2.5-pro",
          "description": "Default model to use (e.g. cli-gemini/gemini-2.5-pro, grok-3)"
        },
        "conduit.inlineSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code suggestions (ghost text) while typing"
        },
        "conduit.inlineTriggerDelay": {
          "type": "number",
          "default": 600,
          "description": "Delay in ms before requesting inline suggestion"
        },
        "conduit.contextLines": {
          "type": "number",
          "default": 80,
          "description": "Number of lines above/below cursor to include as context"
        },
        "conduit.includeOpenFiles": {
          "type": "boolean",
          "default": true,
          "description": "Include other open editor tabs as additional context"
        },
        "conduit.maxOpenFilesContext": {
          "type": "number",
          "default": 3,
          "description": "Max number of open files to include as context"
        },
        "conduit.terminalIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Enable terminal command suggestions"
        },
        "conduit.autoStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show provider status in status bar"
        },
        "conduit.agentMaxIterations": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of model calls in a single agent loop run"
        },
        "conduit.agentAutoApprove": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve destructive agent actions (file writes, terminal commands) without confirmation"
        },
        "conduit.localEndpoints": {
          "type": "array",
          "default": [],
          "description": "Local OpenAI-compatible endpoints (Ollama, LM Studio, llama.cpp). Each entry: {name, url, apiKey?}",
          "items": {
            "type": "object",
            "required": [
              "name",
              "url"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this endpoint (e.g. 'Ollama', 'LM Studio')"
              },
              "url": {
                "type": "string",
                "description": "Base URL of the OpenAI-compatible API (e.g. http://localhost:11434/v1)"
              },
              "apiKey": {
                "type": "string",
                "description": "Optional API key (most local servers don't need one)"
              }
            }
          }
        },
        "conduit.maxSessionCost": {
          "type": "number",
          "default": 0,
          "description": "Maximum cost (USD) per agent session before auto-kill. Set to 0 to disable.",
          "minimum": 0
        }
      }
    },
    "commands": [
      {
        "command": "conduit.openChat",
        "title": "Conduit: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "conduit.switchModel",
        "title": "Conduit: Switch Model",
        "icon": "$(settings-gear)"
      },
      {
        "command": "conduit.explainSelection",
        "title": "Conduit: Explain Selected Code"
      },
      {
        "command": "conduit.refactorSelection",
        "title": "Conduit: Refactor Selected Code"
      },
      {
        "command": "conduit.generateTests",
        "title": "Conduit: Generate Tests for Selection"
      },
      {
        "command": "conduit.fixDiagnostics",
        "title": "Conduit: Fix Errors in File"
      },
      {
        "command": "conduit.askInTerminal",
        "title": "Conduit: Suggest Terminal Command"
      },
      {
        "command": "conduit.inlineEdit",
        "title": "Conduit: Inline Edit (prompt)",
        "icon": "$(edit)"
      },
      {
        "command": "conduit.toggleInline",
        "title": "Conduit: Toggle Inline Suggestions"
      },
      {
        "command": "conduit.checkStatus",
        "title": "Conduit: Check Proxy Status"
      },
      {
        "command": "conduit.showBridgePanel",
        "title": "Conduit: Bridge Manager",
        "icon": "$(server-process)"
      },
      {
        "command": "conduit.startBridge",
        "title": "Conduit: Start Bridge"
      },
      {
        "command": "conduit.stopBridge",
        "title": "Conduit: Stop Bridge"
      },
      {
        "command": "conduit.restartBridge",
        "title": "Conduit: Restart Bridge"
      },
      {
        "command": "conduit.bridgeLogs",
        "title": "Conduit: Show Bridge Logs"
      },
      {
        "command": "conduit.showHealthPanel",
        "title": "Conduit: Health Dashboard",
        "icon": "$(pulse)"
      },
      {
        "command": "conduit.loginGrok",
        "title": "Conduit: Login — Grok"
      },
      {
        "command": "conduit.loginClaude",
        "title": "Conduit: Login — Claude"
      },
      {
        "command": "conduit.loginGemini",
        "title": "Conduit: Login — Gemini"
      },
      {
        "command": "conduit.loginChatGPT",
        "title": "Conduit: Login — ChatGPT"
      },
      {
        "command": "conduit.refreshModels",
        "title": "Conduit: Refresh Models",
        "icon": "$(refresh)"
      },
      {
        "command": "conduit.inlineChat",
        "title": "Conduit: Inline Chat",
        "icon": "$(edit)"
      },
      {
        "command": "conduit.generateCommitMessage",
        "title": "Conduit: Generate Commit Message",
        "icon": "$(git-commit)"
      },
      {
        "command": "conduit.newSession",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "conduit.refreshSessions",
        "title": "Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "conduit.loadSession",
        "title": "Load Session"
      },
      {
        "command": "conduit.deleteSessionFromTree",
        "title": "Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "conduit.renameSession",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "conduit.moveToSecondarySidebar",
        "title": "Conduit: Move to Secondary Sidebar",
        "icon": "$(move)"
      },
      {
        "command": "conduit.spawnAgent",
        "title": "Conduit: Spawn Background Agent",
        "icon": "$(play)"
      },
      {
        "command": "conduit.killSession",
        "title": "Conduit: Kill Agent Session",
        "icon": "$(debug-stop)"
      },
      {
        "command": "conduit.viewAgentOutput",
        "title": "Conduit: View Agent Output",
        "icon": "$(output)"
      },
      {
        "command": "conduit.fixIssue",
        "title": "Conduit: Fix Issue (Worktree + Agent)",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "conduit.batchFixIssues",
        "title": "Conduit: Batch Fix Issues (Label Filter + Parallel Agents)",
        "icon": "$(checklist)"
      },
      {
        "command": "conduit.resumeSession",
        "title": "Resume Interrupted Session",
        "category": "Conduit"
      },
      {
        "command": "conduit.removeSession",
        "title": "Remove Finished Session",
        "category": "Conduit"
      },
      {
        "command": "conduit.clearFinishedSessions",
        "title": "Clear All Finished Sessions",
        "category": "Conduit"
      },
      {
        "command": "conduit.sessionCostSummary",
        "title": "Session Cost Summary",
        "category": "Conduit"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "conduit.explainSelection",
          "when": "editorHasSelection",
          "group": "conduit@1"
        },
        {
          "command": "conduit.refactorSelection",
          "when": "editorHasSelection",
          "group": "conduit@2"
        },
        {
          "command": "conduit.generateTests",
          "when": "editorHasSelection",
          "group": "conduit@3"
        },
        {
          "command": "conduit.inlineEdit",
          "when": "editorHasSelection",
          "group": "conduit@4"
        }
      ],
      "view/title": [
        {
          "command": "conduit.newSession",
          "when": "view == conduit.sessionsView",
          "group": "navigation"
        },
        {
          "command": "conduit.refreshSessions",
          "when": "view == conduit.sessionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "conduit.renameSession",
          "when": "view == conduit.sessionsView",
          "group": "inline@1"
        },
        {
          "command": "conduit.deleteSessionFromTree",
          "when": "view == conduit.sessionsView && viewItem == session",
          "group": "inline@2"
        },
        {
          "command": "conduit.killSession",
          "when": "view == conduit.sessionsView && viewItem == runningAgent",
          "group": "inline@1"
        },
        {
          "command": "conduit.viewAgentOutput",
          "when": "view == conduit.sessionsView && viewItem =~ /runningAgent|completedAgent/",
          "group": "inline@2"
        },
        {
          "command": "conduit.resumeSession",
          "when": "viewItem == 'interruptedAgent'",
          "group": "inline"
        },
        {
          "command": "conduit.removeSession",
          "when": "viewItem == 'completedAgent' || viewItem == 'interruptedAgent'",
          "group": "2_manage"
        }
      ],
      "editor/title": [
        {
          "command": "conduit.fixDiagnostics",
          "when": "resourceLangId",
          "group": "conduit"
        }
      ]
    },
    "keybindings": [
      {
        "command": "conduit.openChat",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "conduit.inlineEdit",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorHasSelection"
      },
      {
        "command": "conduit.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "conduit.inlineChat",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "conduit.generateCommitMessage",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conduit-panel",
          "title": "Conduit AI",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "conduit-panel": [
        {
          "type": "webview",
          "id": "conduit.chatView",
          "name": "Chat",
          "visibility": "visible"
        },
        {
          "id": "conduit.sessionsView",
          "name": "Sessions",
          "visibility": "visible"
        }
      ]
    },
    "languages": []
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "dev": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@elvatis_com/agent-backends": "^1.0.0"
  }
}
